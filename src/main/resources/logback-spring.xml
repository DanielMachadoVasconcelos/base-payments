<configuration>
    <import class="ch.qos.logback.classic.encoder.PatternLayoutEncoder" />
    <import class="ch.qos.logback.core.ConsoleAppender" />

    <property name="LOKI_URL" value="${LOKI_URL:-http://localhost:3100/loki/api/v1/push}"/>

    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %magenta(%d{HH:mm:ss.SSSXXX}) %highlight(%-5level) [correlationId=%X{correlationId:-}] [traceId=%X{traceId:-}] --- %cyan([%15.15t]) %yellow(%logger{39}) : %msg %mdc%n%throwable
            </pattern>
        </encoder>
    </appender>

    <appender name="Loki" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${LOKI_URL}</url>
        </http>
        <format>
            <label>
                <pattern>service=base-payments,level=%level,environment=${spring.profiles.active:-local},traceId=%X{traceId:-none},correlationId=%X{correlationId:-none}</pattern>
            </label>
            <message>
                <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} [%thread] %-5level %logger{36} : %msg traceId=%X{traceId:-none} correlationId=%X{correlationId:-none}%replace(%ex){'[\r\n]+',' | '}</pattern>
            </message>
        </format>
        <batch>
            <bufferSize>250</bufferSize>
            <maxDelay>PT5S</maxDelay>
        </batch>
    </appender>


    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <logger name="org.springframework.boot.autoconfigure" level="ERROR"/>
    <logger name="org.apache.juli.logging.DirectJDKLog" level="ERROR"/>
    <logger name="org.springframework.jdbc.core.JdbcTemplate" level="INFO"/>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="Console"/>
            <appender-ref ref="Loki"/>
        </root>
    </springProfile>
    <springProfile name="!local">
        <root level="INFO">
            <appender-ref ref="Console"/>
            <appender-ref ref="Loki"/>
        </root>
    </springProfile>

</configuration>
