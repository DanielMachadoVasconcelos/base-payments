<configuration>
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %magenta(%d{HH:mm:ss.SSSXXX}) %highlight(%-5level) [correlationId=%X{correlationId:-}] [traceId=%X{traceId:-}] --- %cyan([%15.15t]) %yellow(%logger{39}) : %msg %mdc%n%throwable
            </pattern>
        </encoder>
    </appender>

    <logger name="org.springframework.boot.autoconfigure" level="ERROR"/>
    <logger name="org.apache.juli.logging.DirectJDKLog" level="ERROR"/>
    <logger name="org.springframework.jdbc.core.JdbcTemplate" level="INFO"/>

    <springProfile name="integration-test">
        <root level="INFO">
            <appender-ref ref="Console"/>
        </root>
    </springProfile>
    <springProfile name="!integration-test">
        <appender name="OpenTelemetry" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
            <!-- trace/span ids come from the active context; capture the custom MDC keys explicitly -->
            <captureMdcAttributes>correlationId,x-mocked-issuer</captureMdcAttributes>
            <captureCodeAttributes>true</captureCodeAttributes>
        </appender>
        <root level="INFO">
            <appender-ref ref="Console"/>
            <appender-ref ref="OpenTelemetry"/>
        </root>
    </springProfile>

</configuration>
