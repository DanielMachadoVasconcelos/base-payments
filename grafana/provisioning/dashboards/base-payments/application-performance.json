{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "12.4.2"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "avg(process_cpu_usage{job=\"com.ead.payments/base-payments\"}) * 100",
          "instant": true,
          "legendFormat": "CPU",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(jvm_memory_used_bytes{job=\"com.ead.payments/base-payments\", area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{job=\"com.ead.payments/base-payments\", area=\"heap\"}), 1)",
          "instant": true,
          "legendFormat": "Heap",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Heap Utilization",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(jdbc_connections_active{job=\"com.ead.payments/base-payments\"})",
          "instant": true,
          "legendFormat": "Connections",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Active DB Connections",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_requests_milliseconds_count{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\"}[$__rate_interval]))",
          "instant": true,
          "legendFormat": "Requests/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Throughput",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(http_server_requests_milliseconds_count{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\", outcome!=\"SUCCESS\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_milliseconds_count{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\"}[$__rate_interval])), 0.001)",
          "instant": true,
          "legendFormat": "Errors",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_milliseconds_bucket{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\"}[$__rate_interval])))",
          "instant": true,
          "legendFormat": "p95",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP p95 Latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (uri) (rate(http_server_requests_milliseconds_count{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\"}[$__rate_interval]))",
          "legendFormat": "{{uri}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Throughput by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_milliseconds_bucket{job=\"com.ead.payments/base-payments\", uri!~\"/actuator.*\"}[$__rate_interval])))",
          "legendFormat": "{{uri}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP p95 Latency by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (id) (jvm_memory_used_bytes{job=\"com.ead.payments/base-payments\", area=\"heap\"})",
          "legendFormat": "{{id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Heap Memory by Pool",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(spring_kafka_template_milliseconds_count{job=\"com.ead.payments/base-payments\"}[$__rate_interval]))",
          "legendFormat": "Kafka sends/s",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(jvm_gc_pause_milliseconds_bucket{job=\"com.ead.payments/base-payments\"}[$__rate_interval])))",
          "legendFormat": "GC pause p95 (ms)",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Background Runtime Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["base-payments", "performance", "prometheus"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "",
  "title": "Base Payments - Application Performance",
  "uid": "base-payments-performance",
  "version": 1,
  "weekStart": ""
}
