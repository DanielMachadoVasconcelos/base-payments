{
  "id": null,
  "uid": "issuer-authorize-simple",
  "title": "Issuer Authorization (Simple)",
  "tags": ["payments", "issuer", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m"], "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d", "30d"] },
  "templating": { "list": [] },
  "annotations": { "list": [ { "type": "dashboard", "name": "Annotations & Alerts", "enable": true } ] },
  "panels": [
    {
      "id": 20,
      "type": "row",
      "title": "Totals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Issuer Authorize - Requests / Second",
      "description": "Rate of issuer.authorize calls over the last 5 minutes",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "req/s", "decimals": 2 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(issuer_authorize_seconds_count[5m]))",
          "legendFormat": "{{application}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Issuer Authorize - Avg Latency (ms)",
      "description": "Average latency over the last 5 minutes",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "ms", "decimals": 2 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(issuer_authorize_seconds_sum[5m])) / sum(rate(issuer_authorize_seconds_count[5m]))) * 1000",
          "legendFormat": "avg",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Issuer Authorize - Total Calls",
      "description": "Total number of issuer.authorize calls since start",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(issuer_authorize_seconds_count[24h]))",
          "legendFormat": "total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Issuer Authorize - Total 5xx (24h)",
      "description": "5xx responses recorded over the last 24 hours",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(issuer_authorize_seconds_count{status=~\"5..\"}[24h]))",
          "legendFormat": "5xx (24h)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Latency Percentiles",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Latency p50 (ms)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
