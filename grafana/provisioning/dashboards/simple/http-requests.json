    {
      "id": 18,
      "type": "logs",
      "title": "Application Logs (Loki)",
      "description": "Live application logs enriched with correlation and trace identifiers",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 76
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": true,
        "showLabels": true,
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\".*base-payments.*\"}",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 19,
