    {
      "id": 13,
      "type": "table",
      "title": "Business Request Traces",
      "description": "Recent HTTP request traces for business endpoints (orders, products, etc.) excluding actuator/health noise",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 63
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Duration"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "width": 200
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 50,
          "queryType": "traceql",
          "query": "{ resource.service.name = \"base-payments\" && span.kind = server && name !~ \"http .* /actuator/.*\" && name !~ \"http .* /health.*\" }",
          "tableType": "traces"
        }
      ]
    },
    {
      "id": 17,
      "type": "table",
      "title": "Business Traces Summary",
      "description": "Summary of business endpoint traces (filtered to exclude actuator, eureka, etc.)",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 63
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Duration"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": "base-payments",
              "valueType": "string"
            }
          ],
          "limit": 100,
          "queryType": "traceqlSearch",
          "tableType": "traces"
        }
      ]
    },
    {
      "id": 107,
      "type": "row",
      "title": "Logs & Live Traces",
