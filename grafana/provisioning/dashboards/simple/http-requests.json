        "y": 29
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top Endpoints by Request Count",
      "description": "Most frequently accessed endpoints (excluding actuator)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Request Count"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (uri) (increase(http_server_requests_seconds_count{uri!~\"/actuator/.*\"}[$__range])))",
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top Endpoints by Response Time",
      "description": "Endpoints with highest average response time (excluding actuator)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "options": {
        "showHeader": true,
        "sortBy": [
